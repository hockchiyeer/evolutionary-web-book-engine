# GEMINI_API_KEY / VITE_GEMINI_API_KEY: Required for Gemini AI API calls.
# Use VITE_GEMINI_API_KEY for browser-hosted deployments, or GEMINI_API_KEY when
# your host injects runtime environment values that are exposed to the app shell.
# AI Studio deployments may provide GEMINI_API_KEY from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Web SDK configuration for persisted queries and generated WebBooks.
# Enable Anonymous Authentication and Cloud Firestore in your Firebase project.
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="MY_FIREBASE_PROJECT.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="MY_FIREBASE_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="MY_FIREBASE_PROJECT.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_FIREBASE_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="MY_FIREBASE_APP_ID"
VITE_FIREBASE_MEASUREMENT_ID="MY_FIREBASE_MEASUREMENT_ID"
