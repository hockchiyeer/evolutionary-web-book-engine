{
  "stepDefinitions": [
    "tests/cypress/common/*.js",
    "tests/cypress/common/**/*.js"
  ],
  "html": {
    "enabled": true,
    "output": "test-results/cucumber-report.html"
  },
  "messages": {
    "enabled": true,
    "output": "test-results/cucumber-messages.ndjson"
  },
  "json": {
    "enabled": true,
    "output": "test-results/cucumber-report.json"
  },
  "omitFiltered": true,
  "filterSpecs": true
}
